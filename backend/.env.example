# Configurações do Servidor
PORT=5000
NODE_ENV=development
JWT_SECRET=sua_chave_secreta_aqui_para_o_time

# Configurações do Banco de Dados (TiDB Cloud / MySQL)
DB_HOST=gateway01.us-east-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=seu_usuario.root
DB_PASSWORD=sua_senha_do_tidb
DB_NAME=barbearia

# Observação: Para rodar localmente com XAMPP, mude os valores para:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=barbearia
