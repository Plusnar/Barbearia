<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/service_card_category"
    android:layout_width="120dp"
    android:layout_height="140dp"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_scissor"
            android:contentDescription="@string/service_icon"
            android:scaleType="centerInside"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/service_name_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Corte"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/service_price_category"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="R\$ 50,00"
            android:textColor="@color/secondary"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAlignment="center" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
